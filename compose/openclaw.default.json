{
  "agents": {
    "defaults": {
      "workspace": "/home/node/workspace",
      "sandbox": {
        "mode": "all",
        "scope": "agent",
        "workspaceAccess": "rw",
        "docker": {
          "image": "ghcr.io/cruel/openclaw-images/openclaw-sandbox:latest",
          "binds": ["/var/run/docker.sock:/var/run/docker.sock"]
        },
        "browser": {
          "enabled": true,
          "image": "ghcr.io/cruel/openclaw-images/openclaw-sandbox-browser:latest"
        }
      }
    }
  },
  "tools": {
    "exec": {
      "host": "sandbox",
      "security": "allowlist",
      "ask": "on-miss"
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "https://your.domain.com"
      ]
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  }
}